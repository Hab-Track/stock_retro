		 	<script>
			function updateOnlineCount() {
				fetch('counter.php')
					.then(response => response.text())
					.then(data => {
						const onlineCountElement = document.getElementById('onlineCount');
						const cleanData = data.trim();

						if (onlineCountElement) {
							onlineCountElement.classList.add('updating');

							setTimeout(() => {
								onlineCountElement.innerText = cleanData;

								
								onlineCountElement.classList.remove('updating');
							}, 500);
						}
					})
					.catch(error => console.error('Erro ao atualizar o contador:', error));
			}	

			document.addEventListener('DOMContentLoaded', () => {
				updateOnlineCount(); 
				setInterval(updateOnlineCount, 15000); 
			});
			</script> 
